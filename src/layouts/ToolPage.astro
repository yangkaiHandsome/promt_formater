---
import BaseLayout from './BaseLayout.astro';
import AdSlot from '../components/AdSlot.astro';

interface Props {
  title: string;
  description: string;
  h1: string;
  intro: string;
  path?: string;
}
const { title, description, h1, intro, path } = Astro.props;
---

<BaseLayout title={title} description={description} path={path}>
  <div class="mx-auto max-w-7xl px-4 py-8">
    <header class="mb-6">
      <h1 class="text-2xl font-bold text-slate-900 sm:text-3xl">{h1}</h1>
      <p class="mt-2 max-w-3xl text-slate-600">{intro}</p>
    </header>

    <!-- 工具本体（React 岛，由各页面通过默认 slot 注入） -->
    <slot />

    <AdSlot />

    <!-- SEO 正文：说明 + FAQ（由页面通过 "content" slot 注入） -->
    <article class="prose-slate mx-auto max-w-3xl text-slate-700">
      <slot name="content" />
    </article>
  </div>
</BaseLayout>
