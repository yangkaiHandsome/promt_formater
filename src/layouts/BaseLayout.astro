---
import { SITE } from '../config';
import ToolIcon from '../components/ToolIcon.astro';
import { canonicalUrl } from '../lib/seo';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  /** 覆盖 canonical 路径，默认取当前页面路径 */
  path?: string;
}

const { title, description, path } = Astro.props;
const canonical = canonicalUrl(path ?? Astro.url.pathname);
const fullTitle = title.includes(SITE.name) ? title : `${title} · ${SITE.name}`;
const ogImage = new URL(SITE.ogImage, SITE.domain).toString();

// 全站结构化数据：让 Google 理解品牌实体（有利于 sitelinks / 知识面板）。
// 页面级的 SoftwareApplication / FAQPage 由各页通过 slot="head" 另外注入，互不冲突。
const siteJsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': `${SITE.domain}/#organization`,
      name: SITE.name,
      url: `${SITE.domain}/`,
      logo: new URL('/logo.png', SITE.domain).toString(),
    },
    {
      '@type': 'WebSite',
      '@id': `${SITE.domain}/#website`,
      name: SITE.name,
      url: `${SITE.domain}/`,
      description: SITE.tagline,
      publisher: { '@id': `${SITE.domain}/#organization` },
      inLanguage: 'en',
    },
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#4f46e5" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/logo.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <link rel="canonical" href={canonical} />

    {
      SITE.googleSiteVerification && (
        <meta name="google-site-verification" content={SITE.googleSiteVerification} />
      )
    }

    <!-- Open Graph / Twitter：分享和搜索预览 -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${SITE.name} — ${SITE.tagline}`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- 全站品牌结构化数据 -->
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(siteJsonLd)}
    />

    <!-- AdSense 脚本位：审核通过并开启后自动加载 -->
    {
      SITE.adsenseEnabled && (
        <link rel="preconnect" href="https://pagead2.googlesyndication.com" crossorigin />
      )
    }
    {
      SITE.adsenseEnabled && (
        <script
          is:inline
          async
          src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${SITE.adsenseClient}`}
          crossorigin="anonymous"
        />
      )
    }

    <!-- 页面级 <head> 注入位：结构化数据(JSON-LD) 等 -->
    <slot name="head" />
  </head>
  <body class="min-h-screen bg-slate-50 text-slate-800 antialiased">
    <header class="border-b border-slate-200 bg-white">
      <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3">
        <a href="/" class="flex items-center gap-2 text-lg font-bold text-slate-900">
          <ToolIcon name="brand" label={`${SITE.name} logo`} class="h-7 w-7" /> {SITE.name}
        </a>
        <nav class="flex items-center gap-1 text-sm font-medium text-slate-600">
          <a class="rounded-md px-3 py-1.5 hover:bg-slate-100" href="/prompt/">Prompt</a>
          <a class="hidden rounded-md px-3 py-1.5 hover:bg-slate-100 sm:block" href="/guides/">Guides</a>
          <a class="hidden rounded-md px-3 py-1.5 hover:bg-slate-100 sm:block" href="/markdown/">Markdown</a>
          <a class="hidden rounded-md px-3 py-1.5 hover:bg-slate-100 sm:block" href="/html/">HTML</a>
          <a class="hidden rounded-md px-3 py-1.5 hover:bg-slate-100 sm:block" href="/json/">JSON</a>
          <a class="hidden rounded-md px-3 py-1.5 hover:bg-slate-100 sm:block" href="/diff/">Diff</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="mt-16 border-t border-slate-200 bg-white">
      <div
        class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-2 px-4 py-6 text-sm text-slate-500 sm:flex-row"
      >
        <p>© {SITE.name} — {SITE.tagline}</p>
        <nav class="flex flex-wrap justify-center gap-x-4 gap-y-2">
          <a class="hover:text-slate-800" href="/prompt/">Prompt</a>
          <a class="hover:text-slate-800" href="/markdown/">Markdown</a>
          <a class="hover:text-slate-800" href="/html/">HTML</a>
          <a class="hover:text-slate-800" href="/json/">JSON</a>
          <a class="hover:text-slate-800" href="/diff/">Diff</a>
          <a class="hover:text-slate-800" href="/guides/">Guides</a>
          <a class="hover:text-slate-800" href="/about/">About</a>
          <a class="hover:text-slate-800" href="/privacy/">Privacy</a>
          <a class="hover:text-slate-800" href="/contact/">Contact</a>
        </nav>
      </div>
    </footer>

    <!-- Cloudflare Web Analytics -->
    <script
      is:inline
      defer
      src="https://static.cloudflareinsights.com/beacon.min.js"
      data-cf-beacon='{"token": "8a4a768fb1cf48b3836171484fd329fc"}'></script>
    <!-- End Cloudflare Web Analytics -->
  </body>
</html>
