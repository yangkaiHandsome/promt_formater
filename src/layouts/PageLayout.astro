---
// 非工具的内容页壳（About / Privacy / Contact 等）。
// 单栏 prose 排版，供 AdSense 审核所需的信任页与静态说明使用。
import BaseLayout from './BaseLayout.astro';
import { SITE } from '../config';
import { canonicalUrl } from '../lib/seo';

interface Props {
  title: string;
  description: string;
  h1: string;
  updated?: string;
  published?: string;
  path?: string;
  article?: boolean;
}
const { title, description, h1, updated, published, path, article = false } = Astro.props;
const canonical = canonicalUrl(path ?? Astro.url.pathname);
const articleSchema = article
  ? {
      '@context': 'https://schema.org',
      '@type': 'TechArticle',
      headline: h1,
      description,
      url: canonical,
      mainEntityOfPage: canonical,
      datePublished: published ?? updated,
      dateModified: updated ?? published,
      author: { '@type': 'Organization', name: `${SITE.name} maintainers`, url: canonicalUrl('/about/') },
      publisher: { '@type': 'Organization', name: SITE.name, url: SITE.domain },
      inLanguage: 'en',
    }
  : null;
---

<BaseLayout title={title} description={description} path={path}>
  {articleSchema && <script type="application/ld+json" slot="head" is:inline set:html={JSON.stringify(articleSchema)} />}
  <div class="mx-auto max-w-3xl px-4 py-12">
    <header class="mb-8">
      {article && <p class="font-mono text-xs font-bold uppercase tracking-[0.2em] text-brand-600">Developer field guide</p>}
      <h1 class="text-3xl font-bold text-slate-900">{h1}</h1>
      {article && (
        <div class="mt-4 flex flex-wrap items-center gap-x-3 gap-y-1 border-y border-slate-200 py-3 text-sm text-slate-500">
          <span>Written and maintained by <a class="font-semibold text-slate-700" href="/about/">{SITE.name}</a></span>
          {updated && <><span aria-hidden="true">·</span><span>Verified {updated}</span></>}
        </div>
      )}
      {!article && updated && <p class="mt-2 text-sm text-slate-500">Last updated: {updated}</p>}
    </header>
    <article class="prose-slate max-w-none text-slate-700 [&_a]:text-brand-600 [&_a]:underline [&_blockquote]:my-6 [&_blockquote]:border-l-4 [&_blockquote]:border-emerald-400 [&_blockquote]:bg-emerald-50 [&_blockquote]:px-5 [&_blockquote]:py-3 [&_code]:rounded [&_code]:bg-slate-100 [&_code]:px-1 [&_code]:py-0.5 [&_h2]:mt-10 [&_h2]:text-2xl [&_h2]:font-black [&_h2]:tracking-tight [&_h2]:text-slate-900 [&_h3]:mt-6 [&_h3]:font-bold [&_h3]:text-slate-900 [&_ol]:mt-3 [&_ol]:list-decimal [&_ol]:space-y-2 [&_ol]:pl-6 [&_p]:mt-3 [&_p]:leading-7 [&_pre]:my-5 [&_pre]:overflow-x-auto [&_pre]:rounded-xl [&_pre]:bg-slate-950 [&_pre]:p-4 [&_pre]:text-sm [&_pre]:text-slate-200 [&_ul]:mt-3 [&_ul]:list-disc [&_ul]:space-y-2 [&_ul]:pl-6">
      <slot />
    </article>
  </div>
</BaseLayout>
