---
import PageLayout from '../layouts/PageLayout.astro';
import { SITE } from '../config';
---

<PageLayout
  title={`Contact ${SITE.name}`}
  description={`Get in touch with the ${SITE.name} team — feedback, bug reports, tool requests or privacy questions.`}
  h1="Contact Us"
  path="/contact"
>
  <p>
    We'd love to hear from you. Whether you found a bug, want to request a new
    formatter, have a partnership idea, or a question about your privacy — send
    us a note and we'll get back to you.
  </p>

  <h2>Email</h2>
  <p>
    <a href={`mailto:${SITE.contactEmail}`}>{SITE.contactEmail}</a>
  </p>

  <h2>What to include</h2>
  <ul>
    <li>Which tool you were using (Prompt, Markdown or HTML).</li>
    <li>What you expected to happen and what actually happened.</li>
    <li>A sample input, if it's safe to share (remember, we never see it otherwise).</li>
  </ul>

  <p>
    For details on how we handle any information you send us, see our
    <a href="/privacy">Privacy Policy</a>.
  </p>
</PageLayout>
