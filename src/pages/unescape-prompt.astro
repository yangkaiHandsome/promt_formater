---
import ToolPage from '../layouts/ToolPage.astro';
import PromptTool from '../components/PromptTool.tsx';
import PromptToolLinks from '../components/PromptToolLinks.astro';
---

<ToolPage
  title="Unescape Prompt Online — Turn \n Back Into Real Line Breaks"
  description="Paste a prompt full of \n, \t and escaped quotes and get real line breaks back instantly. Free online tool to unescape LLM prompts copied from logs or JSON."
  h1="Unescape a Prompt"
  intro="Copied a prompt out of a log line or JSON string that is full of escaped newlines and quotes? Paste it on the left and get real, readable line breaks on the right — instantly, in your browser."
  path="/unescape-prompt"
  faq={[
    {
      q: 'Is it private?',
      a: "Yes. Everything runs entirely in your browser — nothing is uploaded — so it's safe to paste real prompts and production data.",
    },
  ]}
>
  <PromptTool client:only="react" />

  <Fragment slot="content">
    <h2 class="mt-8 text-xl font-bold text-slate-900">Why is my prompt full of \n?</h2>
    <p class="mt-2">
      When a prompt is serialized into JSON or written to a log, real line breaks become the two
      characters <code>\n</code>, tabs become <code>\t</code>, and quotes become escaped quotes.
      Copy that string back out and you get one dense, unreadable line. This tool reverses the
      escaping so the prompt looks the way the model actually received it.
    </p>

    <h2 class="mt-6 text-xl font-bold text-slate-900">What gets unescaped</h2>
    <ul class="mt-2 list-disc space-y-1 pl-6">
      <li><code>\n</code> → real newlines</li>
      <li><code>\t</code> → tabs / indentation</li>
      <li><code>\&quot;</code> and <code>\\</code> → literal quotes and backslashes</li>
      <li>Inline JSON payloads are pretty-printed so they're readable too</li>
    </ul>

    <h2 class="mt-6 text-xl font-bold text-slate-900">Is it private?</h2>
    <p class="mt-2">
      Yes. Everything runs entirely in your browser — nothing is uploaded — so it's safe to paste
      real prompts and production data.
    </p>
    <p class="mt-4">
      Need more than unescaping? The full
      <a class="text-brand-600 underline" href="/prompt-formatter">prompt formatter</a>
      also splits system/user/assistant roles into separate blocks.
    </p>

    <PromptToolLinks current="/unescape-prompt" />
  </Fragment>
</ToolPage>
