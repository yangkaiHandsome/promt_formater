---
import ToolPage from '../layouts/ToolPage.astro';
import HtmlTool from '../components/HtmlTool.tsx';
---

<ToolPage
  title="HTML Viewer Online — Run & Preview HTML Free"
  description="Free online HTML viewer. Paste HTML code and preview it rendered instantly in a safe sandbox. No sign-up, runs in your browser."
  h1="HTML Viewer — Preview HTML Online"
  intro="Paste your HTML code and see it rendered right away. The preview runs in a sandboxed iframe with scripts disabled, so it's safe to test any snippet."
  path="/html-viewer"
>
  <HtmlTool client:only="react" />

  <Fragment slot="content">
    <h2 class="mt-8 text-xl font-bold text-slate-900">See your HTML rendered instantly</h2>
    <p class="mt-2">
      Paste a snippet, an email template, or a full page and preview how it looks — no local file, no
      setup. Switch to <strong>Format</strong> to beautify messy markup. Everything runs in your
      browser and nothing is uploaded.
    </p>
    <p class="mt-4">
      Need to convert Markdown instead? Try the
      <a class="text-brand-600 underline" href="/markdown-to-html">Markdown to HTML converter</a>.
    </p>
  </Fragment>
</ToolPage>
