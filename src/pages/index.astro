---
import BaseLayout from '../layouts/BaseLayout.astro';
import AdSlot from '../components/AdSlot.astro';
import ToolIcon from '../components/ToolIcon.astro';
import { SITE, TOOLS } from '../config';
import { LANDINGS, GROUP_HOME, type ToolGroup } from '../data/landings';

const tools = Object.values(TOOLS);

// 首页直链所有长尾落地页（按 group 归类），把最高权重页的内链传给它们、
// 同时方便用户发现更多具体用法。数据驱动，新增落地页会自动出现在这里。
const groupOrder: ToolGroup[] = ['prompt', 'markdown', 'html'];
const byGroup = groupOrder.map((g) => ({
  group: g,
  home: GROUP_HOME[g],
  items: LANDINGS.filter((l) => l.group === g),
}));
---

<BaseLayout
  title={`${SITE.name} — Free Markdown, HTML & Prompt Formatters`}
  description="Free online tools to format Markdown, render HTML safely, and clean up AI prompts. No sign-up, runs entirely in your browser."
  path="/"
>
  <section class="mx-auto max-w-6xl px-4 py-14 text-center">
    <h1 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-5xl">
      Make your logged LLM prompts readable
    </h1>
    <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-600">
      Paste a messy, escaped prompt from your logs and get a clean, color-coded conversation —
      roles split, <code class="rounded bg-slate-100 px-1 py-0.5 text-base">\n</code> unescaped,
      inline JSON pretty-printed. Plus Markdown and HTML formatters. Everything runs in your
      browser — nothing is uploaded.
    </p>

    <div class="mt-12 grid gap-6 sm:grid-cols-3">
      {
        tools.map((t) => (
          <a
            href={t.href}
            class="group flex flex-col rounded-2xl border border-slate-200 bg-white p-8 text-left shadow-sm transition hover:-translate-y-1 hover:border-brand-500 hover:shadow-md"
          >
            <span class="grid h-12 w-12 place-items-center rounded-xl border border-slate-200 bg-white shadow-sm ring-4 ring-slate-50 transition group-hover:border-brand-100 group-hover:ring-brand-50">
              <ToolIcon name={t.icon} label={`${t.title} icon`} class="h-9 w-9" />
            </span>
            <h2 class="mt-4 text-xl font-bold text-slate-900 group-hover:text-brand-600">
              {t.title}
            </h2>
            <p class="mt-2 text-sm text-slate-600">{t.blurb}</p>
            <span class="mt-4 text-sm font-semibold text-brand-600">Open tool →</span>
          </a>
        ))
      }
    </div>

    <AdSlot />
  </section>

  <section class="mx-auto max-w-6xl px-4 pb-16">
    <h2 class="text-center text-2xl font-bold text-slate-900">Popular formatters</h2>
    <p class="mx-auto mt-2 max-w-2xl text-center text-slate-600">
      Jump straight to the exact tool you need — every one runs in your browser, free and
      without sign-up.
    </p>
    <div class="mt-8 grid gap-8 sm:grid-cols-3">
      {
        byGroup.map((col) => (
          <div>
            <h3 class="text-sm font-semibold uppercase tracking-wide text-slate-500">
              <a class="hover:text-brand-600" href={col.home.href}>
                {col.home.label}
              </a>
            </h3>
            <ul class="mt-3 space-y-2 text-sm">
              {col.items.map((l) => (
                <li>
                  <a class="text-slate-700 hover:text-brand-600 hover:underline" href={`/${l.slug}`}>
                    {l.h1}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </section>
</BaseLayout>
