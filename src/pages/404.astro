---
// 自定义 404：Cloudflare Pages 会以 404 状态自动服务 /404.html。
// 目标是把点到失效链接的访客/爬虫导回具体工具，减少跳出、回收流量。
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE, TOOLS } from '../config';
import { LANDINGS, GROUP_HOME, type ToolGroup } from '../data/landings';

const tools = Object.values(TOOLS);
const groupOrder: ToolGroup[] = ['prompt', 'markdown', 'html'];
const byGroup = groupOrder.map((g) => ({
  home: GROUP_HOME[g],
  items: LANDINGS.filter((l) => l.group === g),
}));
---

<BaseLayout
  title={`Page not found (404) — ${SITE.name}`}
  description="That page could not be found. Browse our free in-browser formatters for Markdown, HTML and AI prompts instead."
  path="/404"
>
  <section class="mx-auto max-w-6xl px-4 py-16">
    <div class="text-center">
      <p class="text-sm font-semibold uppercase tracking-widest text-brand-600">404</p>
      <h1 class="mt-2 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">
        This page could not be found
      </h1>
      <p class="mx-auto mt-4 max-w-xl text-slate-600">
        The link may be broken or the page may have moved. Pick a formatter below — everything
        runs in your browser, free and without sign-up.
      </p>
      <a
        href="/"
        class="mt-6 inline-block rounded-lg bg-brand-600 px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-brand-700"
      >
        ← Back to home
      </a>
    </div>

    <div class="mt-12 grid gap-6 sm:grid-cols-3">
      {
        tools.map((t) => (
          <a
            href={t.href}
            class="group rounded-2xl border border-slate-200 bg-white p-6 text-left shadow-sm transition hover:-translate-y-1 hover:border-brand-500 hover:shadow-md"
          >
            <h2 class="text-lg font-bold text-slate-900 group-hover:text-brand-600">{t.title}</h2>
            <p class="mt-2 text-sm text-slate-600">{t.blurb}</p>
          </a>
        ))
      }
    </div>

    <div class="mt-10 grid gap-8 sm:grid-cols-3">
      {
        byGroup.map((col) => (
          <div>
            <h3 class="text-sm font-semibold uppercase tracking-wide text-slate-500">
              <a class="hover:text-brand-600" href={col.home.href}>
                {col.home.label}
              </a>
            </h3>
            <ul class="mt-3 space-y-2 text-sm">
              {col.items.map((l) => (
                <li>
                  <a class="text-slate-700 hover:text-brand-600 hover:underline" href={`/${l.slug}`}>
                    {l.h1}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </section>
</BaseLayout>
