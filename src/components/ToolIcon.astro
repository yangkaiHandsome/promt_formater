---
type IconName = 'brand' | 'prompt' | 'markdown' | 'html' | 'json' | 'diff';

interface Props {
  name: IconName;
  label?: string;
  class?: string;
}

const { name, label, class: className = '' } = Astro.props;
const titleId = label ? `tool-icon-${name}` : undefined;
---

{
  name === 'brand' && (
    <svg
      class={className}
      viewBox="0 0 40 40"
      fill="none"
      role={label ? 'img' : 'presentation'}
      aria-hidden={label ? undefined : 'true'}
      aria-labelledby={titleId}
      xmlns="http://www.w3.org/2000/svg"
    >
      {label && <title id={titleId}>{label}</title>}
      <rect x="4" y="4" width="32" height="32" rx="9" fill="#F8FAFC" />
      <rect x="5" y="5" width="30" height="30" rx="8" stroke="#0F172A" stroke-opacity=".08" stroke-width="2" />
      <path d="M13 11h11l4 4v14H13V11Z" fill="#FFFFFF" stroke="#1E293B" stroke-width="2" stroke-linejoin="round" />
      <path d="M24 11v5h5" stroke="#1E293B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
      <path d="M16 19h8M16 24h6" stroke="#64748B" stroke-width="2" stroke-linecap="round" />
      <path d="m25.5 23.5 2.1 2.1 4-5.2" stroke="#0F9F6E" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" />
      <path d="M11.5 13.5h-3M11.5 20h-3M11.5 26.5h-3" stroke="#2D54E0" stroke-width="2.2" stroke-linecap="round" />
    </svg>
  )
}

{
  name === 'prompt' && (
    <svg
      class={className}
      viewBox="0 0 56 56"
      fill="none"
      role={label ? 'img' : 'presentation'}
      aria-hidden={label ? undefined : 'true'}
      aria-labelledby={titleId}
      xmlns="http://www.w3.org/2000/svg"
    >
      {label && <title id={titleId}>{label}</title>}
      <rect x="10" y="13" width="36" height="30" rx="9" fill="#FFFFFF" stroke="#CBD5E1" stroke-width="2" />
      <path d="M18 23h13M18 30h8" stroke="#64748B" stroke-width="2.4" stroke-linecap="round" />
      <path d="M34 24l2.1-4.1L38 24l4.1 2.1L38 28l-1.9 4.1L34 28l-4.1-1.9L34 24Z" fill="#EEF4FF" stroke="#2D54E0" stroke-width="2" stroke-linejoin="round" />
      <path d="M18 37h16" stroke="#2D54E0" stroke-width="2.4" stroke-linecap="round" />
      <path d="M15 13.5V11a5 5 0 0 1 5-5h2" stroke="#E2E8F0" stroke-width="2" stroke-linecap="round" />
    </svg>
  )
}

{
  name === 'markdown' && (
    <svg
      class={className}
      viewBox="0 0 56 56"
      fill="none"
      role={label ? 'img' : 'presentation'}
      aria-hidden={label ? undefined : 'true'}
      aria-labelledby={titleId}
      xmlns="http://www.w3.org/2000/svg"
    >
      {label && <title id={titleId}>{label}</title>}
      <rect x="12" y="9" width="32" height="38" rx="6" fill="#FFFFFF" stroke="#CBD5E1" stroke-width="2" />
      <path d="M19 20h18M19 27h13" stroke="#64748B" stroke-width="2.4" stroke-linecap="round" />
      <path d="M19 35V31l3.8 4 3.8-4v4" stroke="#2D54E0" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round" />
      <path d="M32 31v4.5m0 0 3-3m-3 3-3-3" stroke="#0F9F6E" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round" />
      <path d="M37 9v7h7" stroke="#E2E8F0" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  )
}

{
  name === 'html' && (
    <svg
      class={className}
      viewBox="0 0 56 56"
      fill="none"
      role={label ? 'img' : 'presentation'}
      aria-hidden={label ? undefined : 'true'}
      aria-labelledby={titleId}
      xmlns="http://www.w3.org/2000/svg"
    >
      {label && <title id={titleId}>{label}</title>}
      <rect x="9" y="11" width="38" height="34" rx="8" fill="#FFFFFF" stroke="#CBD5E1" stroke-width="2" />
      <path d="M9 20h38" stroke="#E2E8F0" stroke-width="2" />
      <circle cx="16" cy="16" r="1.5" fill="#94A3B8" />
      <circle cx="21" cy="16" r="1.5" fill="#94A3B8" />
      <path d="m22 27-5 4 5 4M34 27l5 4-5 4" stroke="#2D54E0" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" />
      <path d="m31 25-6 12" stroke="#0F9F6E" stroke-width="2.6" stroke-linecap="round" />
      <path d="M17 40h22" stroke="#E2E8F0" stroke-width="2" stroke-linecap="round" />
    </svg>
  )
}

{
  name === 'json' && (
    <svg
      class={className}
      viewBox="0 0 56 56"
      fill="none"
      role={label ? 'img' : 'presentation'}
      aria-hidden={label ? undefined : 'true'}
      aria-labelledby={titleId}
      xmlns="http://www.w3.org/2000/svg"
    >
      {label && <title id={titleId}>{label}</title>}
      <rect x="11" y="9" width="34" height="38" rx="7" fill="#FFFFFF" stroke="#CBD5E1" stroke-width="2" />
      <path d="M23 16c-4 0-4 3.5-4 6s0 6-4 6c4 0 4 3.5 4 6s0 6 4 6" stroke="#2D54E0" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" />
      <path d="M33 16c4 0 4 3.5 4 6s0 6 4 6c-4 0-4 3.5-4 6s0 6-4 6" stroke="#0F9F6E" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" />
      <circle cx="28" cy="28" r="1.8" fill="#64748B" />
    </svg>
  )
}

{
  name === 'diff' && (
    <svg
      class={className}
      viewBox="0 0 56 56"
      fill="none"
      role={label ? 'img' : 'presentation'}
      aria-hidden={label ? undefined : 'true'}
      aria-labelledby={titleId}
      xmlns="http://www.w3.org/2000/svg"
    >
      {label && <title id={titleId}>{label}</title>}
      <rect x="8" y="11" width="17" height="34" rx="4" fill="#FEF2F2" stroke="#CBD5E1" stroke-width="2" />
      <rect x="31" y="11" width="17" height="34" rx="4" fill="#F0FDF4" stroke="#CBD5E1" stroke-width="2" />
      <path d="M12 19h9M12 25h9M12 31h6" stroke="#DC2626" stroke-width="2.2" stroke-linecap="round" />
      <path d="M35 19h9M35 25h6M35 31h9" stroke="#16A34A" stroke-width="2.2" stroke-linecap="round" />
      <path d="M16.5 38.5h-2.5M15.25 37.25v2.5" stroke="#DC2626" stroke-width="2" stroke-linecap="round" />
