---
// AdSense 广告位占位组件。审核通过前 SITE.adsenseEnabled = false，
// 只渲染一个不显眼的占位框；上线后开启即可自动插入 <ins> 广告单元。
import { SITE } from '../config';

interface Props {
  slot?: string;
  class?: string;
}
const { slot = '0000000000', class: className = '' } = Astro.props;
---

{
  SITE.adsenseEnabled ? (
    <ins
      class:list={['adsbygoogle block', className]}
      style="display:block"
      data-ad-client={SITE.adsenseClient}
      data-ad-slot={slot}
      data-ad-format="auto"
      data-full-width-responsive="true"
    />
    <script is:inline>
      (adsbygoogle = window.adsbygoogle || []).push({});
    </script>
  ) : (
    <div
      class:list={[
        'flex items-center justify-center rounded-lg border border-dashed border-slate-300 bg-slate-50 py-6 text-xs text-slate-400',
        className,
      ]}
    >
      Ad space
    </div>
  )
}
